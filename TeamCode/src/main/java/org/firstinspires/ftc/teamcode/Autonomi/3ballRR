package org.firstinspires.ftc.teamcode.Autonomi;

import androidx.annotation.NonNull;
import com.acmerobotics.dashboard.telemetry.TelemetryPacket;
import com.acmerobotics.roadrunner.Action;
import com.acmerobotics.roadrunner.InstantAction;
import com.acmerobotics.roadrunner.ParallelAction;
import com.acmerobotics.roadrunner.Pose2d;
import com.acmerobotics.roadrunner.SequentialAction;
import com.acmerobotics.roadrunner.Vector2d;
import com.acmerobotics.roadrunner.ftc.Actions;
import com.qualcomm.robotcore.eventloop.opmode.LinearOpMode;
import com.qualcomm.robotcore.hardware.CRServo;
import com.qualcomm.robotcore.hardware.DcMotorEx;
import com.qualcomm.robotcore.hardware.Servo;
import org.firstinspires.ftc.teamcode.MecanumDrive;

public class Red3Auto extends LinearOpMode{

        DcMotorEx launcher;
        DcMotorEx intake;
        Servo stopper;

        MecanumDrive drive;

        @Override
        public void runOpMode() {

            Pose2d beginPose = new Pose2d( new Vector2d( -50, -50), Math.toRadians(135) );
            drive = new MecanumDrive(hardwareMap, beginPose);
            launcher = hardwareMap.get(DcMotorEx.class, "launcher");
            intake = hardwareMap.get(DcMotorEx.class, "intake");
            stopper = hardwareMap.get(Servo.class, "stopper");
            waitForStart();

            // --- Launcher action ---
            Action spinLauncher = new Action() {
                @Override
                public boolean run(@NonNull TelemetryPacket packet) {
                    launcher.setVelocity(3000);   // spin launcher
                    return true;              // keep running
                }
            };
            Action slowtake = new Action() {
                @Override
                public boolean run(@NonNull TelemetryPacket packet) {
                    intake.setVelocity(100);   // spin intake
                    return true;              // keep running
                }
            };
            Action launchingsequence = new Action() {
                @Override
                public boolean run(@NonNull TelemetryPacket telemetryPacket) {
                    intake.setVelocity(-25);
                    sleep(5);
                    stopper.setPosition(0.25);
                    intake.setVelocity(300);
                    stopper.setPosition(0);
                    while (true) {
                        int i = 3000;
                        if (launcher.getVelocity() > i) break;
                    }
                    stopper.setPosition(0.25);
                    return false;
                }
            };
            // --- Stop launcher action ---
            Action stopLauncher = new InstantAction(() -> launcher.setPower(0));
            Action stopIntake = new InstantAction(() -> intake.setPower(0));


            // --- Backward trajectory ---
            Action pathp1 =
                    drive.actionBuilder(beginPose)
                            .lineToX(-15) //moves back
                            .build();
            Action pathp2 =
                    drive.actionBuilder(new Pose2d(-15,15, Math.toRadians(135)))
                            .strafeTo(new Vector2d(5,15))
                            .build();

            // --- Run both at same time ---
            Actions.runBlocking(
                    new SequentialAction(
                            spinLauncher,
                            slowtake,
                            pathp1,
                            launchingsequence,
                            launchingsequence,
                            launchingsequence,
                            stopLauncher,
                            stopIntake,
                            pathp2
                    )
            );
        }
    }
